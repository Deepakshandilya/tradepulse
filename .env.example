# TradePulse — Environment Variables
# Copy this file to .env and fill in your values

# Database
DB_URI=mysql+pymysql://root:yourpassword@localhost/tradepulse

# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development

# MetaTrader 5
MT5_LOGIN=123456
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Demo

# Redis (required for Trade Copier)
# Default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Trade Copier — Paths to each MT5 terminal installation
# MT5_MASTER_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
# MT5_SLAVE_TERMINAL_PATH=C:\MT5_Slave\terminal64.exe
